{
    "name": "veronikadzhatieva/lab4",
    "description": "Lab 4 with API - CI/CD Ready",
    "type": "project",
    "require": {
        "guzzlehttp/guzzle": "*",
        "predis/predis": "^3.4",
        "php-amqplib/php-amqplib": "^3.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "./"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "test-coverage": "phpunit --coverage-text",
        "ci": "composer install --no-interaction --no-progress --prefer-dist && composer test"
    },
    "config": {
        "preferred-install": "dist",
        "allow-plugins": {
            "guzzlehttp/guzzle": true
        }
    },
    "minimum-stability": "stable"
}